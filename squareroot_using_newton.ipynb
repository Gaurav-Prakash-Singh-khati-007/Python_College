   ],
   "source": [
    "a=int(input(\"Enter a number to find square root\"))\n",
    "if(a<0):\n",
    "    print(\"square root cannot be achieved\")\n",
    "x=a\n",
    "episilon=0.000001\n",
    "while(True):\n",
    "    prev=x\n",
    "    x=(x+a/x)/2\n",
    "    if(abs(x-prev)<episilon):\n",
    "        break\n",
    "print(x)\n"
   ]
